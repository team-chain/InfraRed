# InfraRed local environment example.
# Copy this file to .env, then generate AGENT_TOKEN with scripts/generate_jwt.py.

ENV=local
LOG_LEVEL=INFO
TZ=Asia/Seoul
CORS_ORIGINS=http://localhost:3000

# Shared demo tenant.
TENANT_ID=company-a
AGENT_ID=agent-001
ASSET_ID=asset-001

# Agent (role A).
AGENT_TOKEN=replace-with-output-of-python-scripts-generate_jwt.py
BACKEND_URL=http://ingestion:8000/ingest
HEARTBEAT_URL=http://ingestion:8000/heartbeat
HEARTBEAT_INTERVAL_SEC=30
AGENT_OFFSET_DB=/var/lib/infrared/offset.sqlite
AGENT_AUTH_LOG_PATH=/host/var/log/auth.log
POLL_INTERVAL_SEC=2

# Ingestion API (role A).
INGEST_HOST=0.0.0.0
INGEST_PORT=8000
PAYLOAD_MAX_BYTES=65536
INTERNAL_API_BASE_URL=http://ingestion:8000

# JWT (roles A and C).
JWT_SECRET=change-me-in-production-please
JWT_ALG=HS256
JWT_ISSUER=infrared
JWT_AUDIENCE=infrared-ingest
JWT_AGENT_TTL_SECONDS=86400
JWT_USER_TTL_SECONDS=3600

# Redis.
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_MAXLEN=100000
DEDUP_TTL_SECONDS=3600

# PostgreSQL.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=infrared
POSTGRES_USER=infrared
POSTGRES_PASSWORD=infrared-dev-pw
DATABASE_URL=postgresql+asyncpg://infrared:infrared-dev-pw@postgres:5432/infrared

# LLM (role C). Leave AWS values empty to use Static Playbook.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
LLM_CACHE_TTL_SECONDS=3600

# Dispatcher (role C).
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alert@infrared.local
ALERT_EMAIL_TO=

# CTI (role B).
CTI_PROVIDER=mock
ABUSEIPDB_API_KEY=
CTI_CACHE_TTL_SECONDS=86400

# Frontend (role C).
VITE_API_BASE_URL=http://localhost:8000
