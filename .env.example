# InfraRed local environment example.
# Copy this file to .env, then generate AGENT_TOKEN with scripts/generate_jwt.py.

ENV=local
LOG_LEVEL=INFO
TZ=Asia/Seoul
CORS_ORIGINS=http://localhost:3000

# Shared demo tenant.
TENANT_ID=company-a
AGENT_ID=agent-001
ASSET_ID=asset-001

# ── First admin bootstrap (env-driven, idempotent) ──────────────────────────
# Set these to auto-create the first admin user on `python -m app.db.migrate`.
# Safe to leave blank locally — the demo seed already creates admin@infrared.local / infrared123.
# REQUIRED for production deploys so fresh deploys are immediately loginable.
# INITIAL_ADMIN_EMAIL=ops@infrared.kr
# INITIAL_ADMIN_PASSWORD=change-me-at-least-8-chars
# INITIAL_ADMIN_TENANT_ID=default
# INITIAL_ADMIN_TENANT_NAME=Default Tenant
# INITIAL_ADMIN_PLAN=mvp

# Agent (role A).
AGENT_TOKEN=replace-with-output-of-python-scripts-generate_jwt.py
BACKEND_URL=http://ingestion:8000/ingest
HEARTBEAT_URL=http://ingestion:8000/heartbeat
HEARTBEAT_INTERVAL_SEC=30
AGENT_OFFSET_DB=/var/lib/infrared/offset.sqlite
AGENT_AUTH_LOG_PATH=/host/var/log/auth.log
POLL_INTERVAL_SEC=2

# Ingestion API (role A).
INGEST_HOST=0.0.0.0
INGEST_PORT=8000
PAYLOAD_MAX_BYTES=65536
INTERNAL_API_BASE_URL=http://ingestion:8000

# JWT (roles A and C).
# WARNING: change JWT_SECRET before deploying. Default value will cause startup error in ENV=prod.
JWT_SECRET=change-me-in-production-please
JWT_ALG=HS256
JWT_ISSUER=infrared
JWT_AUDIENCE=infrared-ingest
JWT_AGENT_TTL_SECONDS=86400
JWT_USER_TTL_SECONDS=3600

# Redis — REDIS_PASSWORD를 docker-compose redis 서비스에 주입.
# REDIS_URL의 password와 REDIS_PASSWORD가 일치해야 함.
# Production: 32+ char random secret. 정기 회전 (180일).
REDIS_PASSWORD=CHANGE_ME_RANDOM_32_CHARS_MIN
REDIS_URL=redis://:CHANGE_ME_RANDOM_32_CHARS_MIN@redis:6379/0
REDIS_STREAM_MAXLEN=100000
DEDUP_TTL_SECONDS=3600

# PostgreSQL.
# Option A - local Docker (default for dev):
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=infrared
POSTGRES_USER=infrared
POSTGRES_PASSWORD=infrared-dev-pw
DATABASE_URL=postgresql+asyncpg://infrared:infrared-dev-pw@postgres:5432/infrared
# Option B - AWS RDS (private VPC, requires public access or VPN):
#   DATABASE_URL=postgresql+asyncpg://<user>:<password>@<rds-endpoint>.rds.amazonaws.com:5432/infrared?ssl=require

# LLM (role C).
# LLM_PROVIDER=static always uses Static Playbook (no AWS required).
# LLM_PROVIDER=bedrock calls AWS Bedrock and falls back to Static Playbook on failure.
# LLM_PROVIDER=auto calls Bedrock only when credentials/profile are configured.
LLM_PROVIDER=auto
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── AWS credentials (보안 원칙) ─────────────────────────────────────────────
# Production EC2:
#   AWS_ACCESS_KEY_ID 와 AWS_SECRET_ACCESS_KEY 를 비워두세요.
#   비워두면 boto3가 EC2 IAM instance role을 자동 사용 (long-lived key 회피).
#   infra/terraform/iam.tf 의 ec2 role 에 Bedrock/S3/SSM 권한이 이미 부여됨.
#
# Local dev:
#   AWS_PROFILE=default 만 설정해서 ~/.aws/credentials 의 SSO/short-lived 사용 권장.
#   또는 AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY 임시 발급 (절대 commit 금지).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# AWS_PROFILE=default
LLM_CACHE_TTL_SECONDS=3600

# Dispatcher (role C).
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alert@infrared.local
ALERT_EMAIL_TO=

# Prometheus metrics endpoint bearer token (leave blank to disable auth).
PROMETHEUS_BEARER_TOKEN=

# ── Sentry error tracking ───────────────────────────────────────────────────
# Leave SENTRY_DSN empty to disable. Backend + frontend both use these.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Frontend (build-time, Vite). Set same or different project DSN.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_TRACES_RATE=0.1

# CTI (role B).
CTI_PROVIDER=mock
ABUSEIPDB_API_KEY=
CTI_CACHE_TTL_SECONDS=86400

# GeoIP (role B).
# MAXMIND_LICENSE_KEY=
# MAXMIND_DB_PATH=/app/data/GeoLite2-City.mmdb

# Detection rule thresholds (role B) ??all adjustable without rebuild.
AUTH_BRUTE_FORCE_THRESHOLD=3
AUTH_BRUTE_FORCE_WINDOW_SECONDS=300
AUTH_INVALID_USER_THRESHOLD=2
AUTH_INVALID_USER_WINDOW_SECONDS=300
AUTH_FAIL_THEN_SUCCESS_WINDOW_SECONDS=600
AUTH_FAIL_THEN_SUCCESS_THRESHOLD=3

# WEB rule thresholds (role B).
WEB_ADMIN_SCAN_THRESHOLD=30
WEB_ADMIN_SCAN_WINDOW_SECONDS=300
WEB_404_THRESHOLD=50
WEB_404_WINDOW_SECONDS=300

# Incident correlation / dedup.
INCIDENT_MERGE_WINDOW_MINUTES=120
INCIDENT_DEDUP_TTL_SECONDS=600

# Dead Letter Queue.
DLQ_MAX_RETRIES=3
DLQ_IDLE_SECONDS=60

# Late event handling.
LATE_EVENT_THRESHOLD_SECONDS=300
LATE_EVENT_MAX_SECONDS=86400

# Frontend (passed to Vite at build time).
VITE_API_BASE_URL=http://localhost:8000

# ── Fluent Bit ─────────────────────────────────────────────────────────────── #
# API key used by Fluent Bit to send logs. Must match a key in the api_keys table.
FLUENTBIT_API_KEY=ir_demo_key_company_a_000000000000
FLUENTBIT_TENANT_ID=company-a

# ── S3 (optional, for Fluent Bit log archival) ─────────────────────────────── #
# Set S3_BUCKET to enable Fluent Bit -> InfraRed API + S3 dual output.
# Use: docker compose --profile full up   (fluentbit is excluded by default)
S3_BUCKET=
AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY  (shared with LLM section above)

# ── v3.0 CTI (AlienVault OTX / AbuseIPDB) ────────────────────────────────── #
# CTI_PROVIDER: otx | abuseipdb | mock  (default: mock)
CTI_PROVIDER=mock
OTX_API_KEY=
ABUSEIPDB_API_KEY=
CTI_CACHE_TTL_SECONDS=3600

# ── v3.0 Response System (TTL-based block approve / reject / extend) ─────── #
AGENT_COMMAND_SECRET=change-me-at-least-32-chars
BLOCK_TTL_SECONDS=1800
BLOCK_EXTEND_TTL_SECONDS=86400
CONFIDENCE_AUTO_BLOCK_THRESHOLD=0.85
CONFIDENCE_APPROVAL_THRESHOLD=0.70

# ── v3.0 Campaign Aggregation ─────────────────────────────────────────────── #
CAMPAIGN_WINDOW_SECONDS=600
CAMPAIGN_MIN_SIGNALS=5
CAMPAIGN_MIN_TARGETS=2

# ── v3.0 Attack Chain Scenario Windows ───────────────────────────────────── #
SCENARIO_SSH_COMPROMISE_WINDOW=600
SCENARIO_WEBSHELL_WINDOW=1200
SCENARIO_PRIV_ESC_WINDOW=300
SCENARIO_RANSOMWARE_WINDOW=180
SCENARIO_LATERAL_WINDOW=600

# ── v3.0 AgentWatchdog ────────────────────────────────────────────────────── #
# Generate with: python scripts/generate_jwt.py --role watchdog
WATCHDOG_TOKEN=
INFRARED_SERVER_URL=http://localhost:8000

# ── v3.0 step-ca PKI ─────────────────────────────────────────────────────── #
STEP_CA_URL=https://step-ca:9000
STEP_CA_ROOT=/home/step/certs/root_ca.crt
